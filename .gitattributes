# Large trained model files are versioned with Git LFS.
models/*.pth filter=lfs diff=lfs merge=lfs -text
models/*.pt filter=lfs diff=lfs merge=lfs -text

# Keep line endings stable across reviewer platforms.
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
